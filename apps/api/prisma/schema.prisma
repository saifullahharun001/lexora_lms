  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  department        Department        @relation(fields: [departmentId], references: [id])
  uploadedByUser    User?             @relation("FileUploadedBy", fields: [uploadedByUserId], references: [id])
  submissionFiles   SubmissionFile[]
  malwareScanResults MalwareScanResult[]

  @@index([departmentId])
  @@map("file_objects")
}

model MalwareScanResult {
  id                String             @id @default(cuid())
  fileObjectId      String             @map("file_object_id")
  scanner           String
  status            MalwareScanStatus
  signatureName     String?            @map("signature_name")
  rawResultJson     Json?              @map("raw_result_json")
  scannedAt         DateTime?          @map("scanned_at")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  fileObject        FileObject         @relation(fields: [fileObjectId], references: [id], onDelete: Cascade)

  @@index([fileObjectId, createdAt])
  @@map("malware_scan_results")
}
