generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_DIRECT_URL")
}

enum DepartmentStatus {
  ACTIVE
  ARCHIVED
  DISABLED
}

enum UserStatus {
  INVITED
  ACTIVE
  LOCKED
  SUSPENDED
  ARCHIVED
}

enum SessionStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum VerificationStatus {
  PENDING
  VERIFIED
  EXPIRED
  CONSUMED
}

enum PermissionScope {
  DEPARTMENT
  SELF
  PUBLIC_VERIFICATION
}

enum TwoFactorMethodType {
  TOTP
  EMAIL_OTP
}

enum AuditActorType {
  USER
  SERVICE
  ANONYMOUS
}

enum AuditOutcome {
  SUCCESS
  FAILURE
  DENIED
}

enum OverrideActionStatus {
  REQUESTED
  APPROVED
  EXECUTED
  REJECTED
  REVOKED
}

enum FileObjectStatus {
  PENDING_SCAN
  AVAILABLE
  QUARANTINED
  REJECTED
  ARCHIVED
  DELETED
}

enum FileVisibility {
  PRIVATE
  DEPARTMENT_INTERNAL
  PUBLIC_VERIFICATION
}

enum MalwareScanStatus {
  PENDING
  CLEAN
  INFECTED
  ERROR
  SKIPPED
}

model Department {
  id                String              @id @default(cuid())
  code              String              @unique
  slug              String              @unique
  name              String
  status            DepartmentStatus    @default(ACTIVE)
  archivedAt        DateTime?           @map("archived_at")
  deletedAt         DateTime?           @map("deleted_at")
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")
  users             User[]
  roles             Role[]
  sessions          Session[]
  emailVerifications EmailVerification[]
  passwordResets    PasswordReset[]
  twoFactorMethods  TwoFactorMethod[]
  settings          DepartmentSetting[]
  auditLogs         AuditLog[]
  overrideActions   OverrideAction[]
  fileObjects       FileObject[]

  @@map("departments")
}

model User {
  id                 String              @id @default(cuid())
  departmentId       String              @map("department_id")
  email              String              @unique
  normalizedEmail    String              @unique @map("normalized_email")
  passwordHash       String?             @map("password_hash")
  displayName        String              @map("display_name")
  status             UserStatus          @default(INVITED)
  lastLoginAt        DateTime?           @map("last_login_at")
  archivedAt         DateTime?           @map("archived_at")
  deletedAt          DateTime?           @map("deleted_at")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  department         Department          @relation(fields: [departmentId], references: [id])
  userRoles          UserRole[]
  sessions           Session[]
  emailVerifications EmailVerification[]
  passwordResets     PasswordReset[]
  twoFactorMethods   TwoFactorMethod[]
  auditLogs          AuditLog[]          @relation("AuditActor")
  settingsUpdated    DepartmentSetting[] @relation("DepartmentSettingUpdatedBy")
  overrideActions    OverrideAction[]    @relation("OverrideActor")
  overrideApprovals  OverrideAction[]    @relation("OverrideApprover")
  fileObjects        FileObject[]        @relation("FileUploadedBy")

  @@index([departmentId])
  @@map("users")
}

model Role {
  id                String           @id @default(cuid())
  departmentId      String           @map("department_id")
  code              String
  name              String
  description       String?
  archivedAt        DateTime?        @map("archived_at")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")
  department        Department       @relation(fields: [departmentId], references: [id])
  userRoles         UserRole[]
  rolePermissions   RolePermission[]

  @@unique([departmentId, code])
  @@index([departmentId])
  @@map("roles")
}

model Permission {
  id               String           @id @default(cuid())
  code             String           @unique
  resource         String
  action           String
  scope            PermissionScope
  description      String?
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")
  rolePermissions  RolePermission[]

  @@map("permissions")
}

model UserRole {
  id               String      @id @default(cuid())
  userId           String      @map("user_id")
  roleId           String      @map("role_id")
  departmentId     String      @map("department_id")
  assignedByUserId String?     @map("assigned_by_user_id")
  expiresAt        DateTime?   @map("expires_at")
  revokedAt        DateTime?   @map("revoked_at")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")
  user             User        @relation(fields: [userId], references: [id])
  role             Role        @relation(fields: [roleId], references: [id])
  department       Department  @relation(fields: [departmentId], references: [id])

  @@unique([userId, roleId, departmentId])
  @@index([departmentId])
  @@map("user_roles")
}

model RolePermission {
  id            String      @id @default(cuid())
  roleId        String      @map("role_id")
  permissionId  String      @map("permission_id")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  role          Role        @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission    Permission  @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model Session {
  id                String         @id @default(cuid())
  userId            String         @map("user_id")
  departmentId      String         @map("department_id")
  refreshTokenHash  String         @map("refresh_token_hash")
  ipAddress         String?        @map("ip_address")
  userAgent         String?        @map("user_agent")
  status            SessionStatus  @default(ACTIVE)
  lastSeenAt        DateTime?      @map("last_seen_at")
  expiresAt         DateTime       @map("expires_at")
  revokedAt         DateTime?      @map("revoked_at")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  department        Department     @relation(fields: [departmentId], references: [id])

  @@index([userId, departmentId])
  @@index([departmentId])
  @@map("sessions")
}

model EmailVerification {
  id             String               @id @default(cuid())
  userId         String               @map("user_id")
  departmentId   String               @map("department_id")
  email          String
  tokenHash      String               @map("token_hash")
  status         VerificationStatus   @default(PENDING)
  expiresAt      DateTime             @map("expires_at")
  verifiedAt     DateTime?            @map("verified_at")
  consumedAt     DateTime?            @map("consumed_at")
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")
  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  department     Department           @relation(fields: [departmentId], references: [id])

  @@index([userId, departmentId])
  @@map("email_verifications")
}

model PasswordReset {
  id             String               @id @default(cuid())
  userId         String               @map("user_id")
  departmentId   String               @map("department_id")
  tokenHash      String               @map("token_hash")
  status         VerificationStatus   @default(PENDING)
  expiresAt      DateTime             @map("expires_at")
  consumedAt     DateTime?            @map("consumed_at")
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")
  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  department     Department           @relation(fields: [departmentId], references: [id])

  @@index([userId, departmentId])
  @@map("password_resets")
}

model TwoFactorMethod {
  id               String              @id @default(cuid())
  userId           String              @map("user_id")
  departmentId     String              @map("department_id")
  methodType       TwoFactorMethodType @map("method_type")
  label            String
  secretEncrypted  String?             @map("secret_encrypted")
  isPrimary        Boolean             @default(false) @map("is_primary")
  verifiedAt       DateTime?           @map("verified_at")
  disabledAt       DateTime?           @map("disabled_at")
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")
  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  department       Department          @relation(fields: [departmentId], references: [id])

  @@index([userId, departmentId])
  @@map("two_factor_methods")
}

model DepartmentSetting {
  id               String      @id @default(cuid())
  departmentId     String      @map("department_id")
  key              String
  valueJson        Json        @map("value_json")
  updatedByUserId  String?     @map("updated_by_user_id")
  archivedAt       DateTime?   @map("archived_at")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")
  department       Department  @relation(fields: [departmentId], references: [id])
  updatedByUser    User?       @relation("DepartmentSettingUpdatedBy", fields: [updatedByUserId], references: [id])

  @@unique([departmentId, key])
  @@index([departmentId])
  @@map("department_settings")
}

model AuditLog {
  id              String          @id @default(cuid())
  requestId       String?         @map("request_id")
  actorUserId     String?         @map("actor_user_id")
  actorType       AuditActorType  @default(USER) @map("actor_type")
  departmentId    String?         @map("department_id")
  action          String
  targetType      String          @map("target_type")
  targetId        String?         @map("target_id")
  outcome         AuditOutcome
  ipAddress       String?         @map("ip_address")
  userAgent       String?         @map("user_agent")
  contextJson     Json?           @map("context_json")
  occurredAt      DateTime        @default(now()) @map("occurred_at")
  actorUser       User?           @relation("AuditActor", fields: [actorUserId], references: [id])
  department      Department?     @relation(fields: [departmentId], references: [id])

  @@index([departmentId, occurredAt])
  @@index([actorUserId, occurredAt])
  @@map("audit_logs")
}

model OverrideAction {
  id               String               @id @default(cuid())
  departmentId     String               @map("department_id")
  actorUserId      String               @map("actor_user_id")
  approvedByUserId String?              @map("approved_by_user_id")
  action           String
  targetType       String               @map("target_type")
  targetId         String?              @map("target_id")
  reason           String
  status           OverrideActionStatus @default(REQUESTED)
  executedAt       DateTime?            @map("executed_at")
  revokedAt        DateTime?            @map("revoked_at")
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")
  department       Department           @relation(fields: [departmentId], references: [id])
  actorUser        User                 @relation("OverrideActor", fields: [actorUserId], references: [id])
  approvedByUser   User?                @relation("OverrideApprover", fields: [approvedByUserId], references: [id])

  @@index([departmentId, createdAt])
  @@map("override_actions")
}

model FileObject {
  id                String            @id @default(cuid())
  departmentId      String            @map("department_id")
  uploadedByUserId  String?           @map("uploaded_by_user_id")
  bucket            String
  objectKey         String            @unique @map("object_key")
  originalFilename  String            @map("original_filename")
  mimeType          String            @map("mime_type")
  sizeBytes         Int               @map("size_bytes")
  checksumSha256    String            @map("checksum_sha256")
  visibility        FileVisibility    @default(PRIVATE)
  status            FileObjectStatus  @default(PENDING_SCAN)
  archivedAt        DateTime?         @map("archived_at")
  deletedAt         DateTime?         @map("deleted_at")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  department        Department        @relation(fields: [departmentId], references: [id])
  uploadedByUser    User?             @relation("FileUploadedBy", fields: [uploadedByUserId], references: [id])
  malwareScanResults MalwareScanResult[]

  @@index([departmentId])
  @@map("file_objects")
}

model MalwareScanResult {
  id                String             @id @default(cuid())
  fileObjectId      String             @map("file_object_id")
  scanner           String
  status            MalwareScanStatus
  signatureName     String?            @map("signature_name")
  rawResultJson     Json?              @map("raw_result_json")
  scannedAt         DateTime?          @map("scanned_at")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  fileObject        FileObject         @relation(fields: [fileObjectId], references: [id], onDelete: Cascade)

  @@index([fileObjectId, createdAt])
  @@map("malware_scan_results")
}
