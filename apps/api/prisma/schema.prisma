generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_DIRECT_URL")
}

enum DepartmentStatus {
  ACTIVE
  ARCHIVED
  DISABLED
}

enum UserStatus {
  INVITED
  ACTIVE
  LOCKED
  SUSPENDED
  ARCHIVED
}

enum SessionStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum LoginAttemptOutcome {
  SUCCESS
  FAILURE
  LOCKED
  STEP_UP_REQUIRED
  BLOCKED
}

enum SuspiciousLoginReason {
  NEW_DEVICE
  NEW_IP
  IMPOSSIBLE_TRAVEL
  EXCESSIVE_FAILURES
  RAPID_SESSION_CHURN
  STEP_UP_FAILURE
}

enum VerificationStatus {
  PENDING
  VERIFIED
  EXPIRED
  CONSUMED
}

enum PermissionScope {
  DEPARTMENT
  SELF
  PUBLIC_VERIFICATION
}

enum TwoFactorMethodType {
  TOTP
  EMAIL_OTP
}

enum AuditActorType {
  USER
  SERVICE
  ANONYMOUS
}

enum AuditOutcome {
  SUCCESS
  FAILURE
  DENIED
}

enum OverrideActionStatus {
  REQUESTED
  APPROVED
  EXECUTED
  REJECTED
  REVOKED
}

enum FileObjectStatus {
  PENDING_SCAN
  AVAILABLE
  QUARANTINED
  REJECTED
  ARCHIVED
  DELETED
}

enum FileVisibility {
  PRIVATE
  DEPARTMENT_INTERNAL
  PUBLIC_VERIFICATION
}

enum MalwareScanStatus {
  PENDING
  CLEAN
  INFECTED
  ERROR
  SKIPPED
}

enum AcademicProgramStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum AcademicYearStatus {
  PLANNED
  ACTIVE
  CLOSED
  ARCHIVED
}

enum AcademicTermStatus {
  PLANNED
  ENROLLMENT_OPEN
  IN_PROGRESS
  CLOSED
  ARCHIVED
}

enum CourseStatus {
  DRAFT
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum CourseOfferingStatus {
  PLANNED
  PUBLISHED
  ENROLLMENT_OPEN
  IN_PROGRESS
  COMPLETED
  CANCELED
  ARCHIVED
}

enum TeacherAssignmentStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum EnrollmentStatus {
  PENDING
  APPROVED
  WAITLISTED
  REJECTED
  DROPPED
  WITHDRAWN
  ARCHIVED
}

enum EnrollmentSourceType {
  ADMIN
  SELF_SERVICE
  IMPORT
  INTEGRATION
}

enum ClassSessionStatus {
  SCHEDULED
  ACTIVE
  COMPLETED
  CANCELED
  LOCKED
  ARCHIVED
}

enum AttendanceRecordStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum AttendanceSourceType {
  MANUAL
  IMPORT
  BIOMETRIC
  SYSTEM
}

enum AttendanceImportBatchStatus {
  RECEIVED
  VALIDATING
  PROCESSED
  PARTIALLY_PROCESSED
  FAILED
  CANCELED
  ARCHIVED
}

enum AttendanceImportSourceType {
  CSV
  BIOMETRIC
  API
  MANUAL_UPLOAD
}

enum EligibilityStatus {
  ELIGIBLE
  INELIGIBLE
  CONDITIONAL
  PENDING_REVIEW
}

enum EligibilityRuleScope {
  DEPARTMENT
  PROGRAM
  TERM
  COURSE_OFFERING
}

enum AssignmentStatus {
  DRAFT
  PUBLISHED
  CLOSED
  ARCHIVED
}

enum SubmissionStatus {
  SUBMITTED
  LATE
  GRADED
  RESUBMITTED
}

enum QuizStatus {
  DRAFT
  PUBLISHED
  ACTIVE
  CLOSED
  ARCHIVED
}

enum QuizAttemptStatus {
  IN_PROGRESS
  SUBMITTED
  AUTO_SUBMITTED
  GRADED
}

enum QuizQuestionType {
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  TRUE_FALSE
  SHORT_TEXT
}

enum GradingRecordTargetType {
  ASSIGNMENT_SUBMISSION
  QUIZ_ATTEMPT
}

enum GradingMode {
  AUTO
  MANUAL
  MIXED
}

enum EvaluationHookStatus {
  NOT_REQUESTED
  PENDING
  COMPLETED
  FAILED
}

enum ResultRecordStatus {
  DRAFT
  COMPUTED
  VERIFIED
  PUBLISHED
  LOCKED
  AMENDED
}

enum ResultPublicationBatchStatus {
  PENDING
  PROCESSING
  PUBLISHED
  FAILED
}

enum ResultAmendmentStatus {
  REQUESTED
  APPROVED
  REJECTED
  APPLIED
}

enum ResultComponentSourceType {
  ASSIGNMENT
  QUIZ
  MANUAL
}

enum TranscriptRecordStatus {
  DRAFT
  GENERATED
  ISSUED
  REVOKED
  ARCHIVED
}

enum TranscriptVersionStatus {
  GENERATED
  ISSUED
  SUPERSEDED
  REVOKED
}

enum TranscriptVerificationTokenStatus {
  ACTIVE
  EXPIRED
  REVOKED
}

enum TranscriptRevocationStatus {
  REQUESTED
  APPLIED
  REJECTED
}

model Department {
  id                String              @id @default(cuid())
  code              String              @unique
  slug              String              @unique
  name              String
  status            DepartmentStatus    @default(ACTIVE)
  archivedAt        DateTime?           @map("archived_at")
  deletedAt         DateTime?           @map("deleted_at")
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")
  users             User[]
  roles             Role[]
  userRoles         UserRole[]
  sessions          Session[]
  emailVerifications EmailVerification[]
  passwordResets    PasswordReset[]
  loginAttempts     LoginAttempt[]
  stepUpRequirements StepUpRequirement[]
  suspiciousLoginEvents SuspiciousLoginEvent[]
  twoFactorMethods  TwoFactorMethod[]
  academicConfig    DepartmentAcademicConfig?
  academicPrograms  AcademicProgram[]
  academicYears     AcademicYear[]
  academicTerms     AcademicTerm[]
  courses           Course[]
  courseOfferings   CourseOffering[]
  teacherAssignments TeacherCourseAssignment[]
  enrollments       Enrollment[]
  classSessions     ClassSession[]
  attendanceRecords AttendanceRecord[]
  attendanceImportBatches AttendanceImportBatch[]
  eligibilityRuleDefinitions EligibilityRuleDefinition[]
  eligibilityRuleBindings EligibilityRuleBinding[]
  assignments       Assignment[]
  assignmentSubmissions AssignmentSubmission[]
  submissionFiles   SubmissionFile[]
  quizzes           Quiz[]
  quizQuestions     QuizQuestion[]
  quizOptions       QuizOption[]
  quizAttempts      QuizAttempt[]
  quizResponses     QuizResponse[]
  gradingRecords    GradingRecord[]
  gradeScales       GradeScale[]
  resultRecords     ResultRecord[]
  resultComponents  ResultComponent[]
  gpaRecords        GPARecord[]
  cgpaRecords       CGPARecord[]
  resultPublicationBatches ResultPublicationBatch[]
  resultAmendmentRecords ResultAmendmentRecord[]
  transcriptRecords  TranscriptRecord[]
  transcriptVersions TranscriptVersion[]
  transcriptTermSummaries TranscriptTermSummary[]
  transcriptCourseLines TranscriptCourseLine[]
  transcriptVerificationTokens TranscriptVerificationToken[]
  transcriptRevocationRecords TranscriptRevocationRecord[]
  transcriptSealMetadatas TranscriptSealMetadata[]
  settings          DepartmentSetting[]
  auditLogs         AuditLog[]
  overrideActions   OverrideAction[]
  fileObjects       FileObject[]

  @@map("departments")
}

model User {
  id                 String              @id @default(cuid())
  departmentId       String              @map("department_id")
  email              String              @unique
  normalizedEmail    String              @unique @map("normalized_email")
  passwordHash       String?             @map("password_hash")
  displayName        String              @map("display_name")
  status             UserStatus          @default(INVITED)
  lastLoginAt        DateTime?           @map("last_login_at")
  archivedAt         DateTime?           @map("archived_at")
  deletedAt          DateTime?           @map("deleted_at")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  department         Department          @relation(fields: [departmentId], references: [id])
  userRoles          UserRole[]
  sessions           Session[]
  emailVerifications EmailVerification[]
  loginAttempts      LoginAttempt[]
  passwordResets     PasswordReset[]
  suspiciousLoginEvents SuspiciousLoginEvent[]
  twoFactorMethods   TwoFactorMethod[]
  academicConfigsUpdated DepartmentAcademicConfig[] @relation("AcademicConfigUpdatedBy")
  teachingAssignments TeacherCourseAssignment[] @relation("TeacherAssignments")
  studentEnrollments Enrollment[] @relation("StudentEnrollments")
  enrollmentApprovals Enrollment[] @relation("EnrollmentApprovedBy")
  attendanceAsStudent AttendanceRecord[] @relation("AttendanceStudent")
  gradedRecords     GradingRecord[] @relation("GradingRecords")
  attendanceMarked AttendanceRecord[] @relation("AttendanceMarkedBy")
  attendanceOverrides AttendanceRecord[] @relation("AttendanceOverrideBy")
  attendanceImportBatchesUploaded AttendanceImportBatch[] @relation("AttendanceImportUploadedBy")
  attendanceImportBatchesReviewed AttendanceImportBatch[] @relation("AttendanceImportReviewedBy")
  gradeScalesUpdated GradeScale[] @relation("GradeScaleUpdatedBy")
  resultsComputed   ResultRecord[] @relation("ResultComputedBy")
  resultsVerified   ResultRecord[] @relation("ResultVerifiedBy")
  resultsPublished  ResultRecord[] @relation("ResultPublishedBy")
  gpaStudentRecords GPARecord[] @relation("GPAStudentRecords")
  gpaRecordsComputed GPARecord[] @relation("GPAComputedBy")
  gpaRecordsPublished GPARecord[] @relation("GPAPublishedBy")
  cgpaStudentRecords CGPARecord[] @relation("CGPAStudentRecords")
  cgpaRecordsComputed CGPARecord[] @relation("CGPAComputedBy")
  cgpaRecordsPublished CGPARecord[] @relation("CGPAPublishedBy")
  resultPublicationBatchesInitiated ResultPublicationBatch[] @relation("ResultPublicationBatchInitiatedBy")
  resultPublicationBatchesPublished ResultPublicationBatch[] @relation("ResultPublicationBatchPublishedBy")
  resultAmendmentsRequested ResultAmendmentRecord[] @relation("ResultAmendmentRequestedBy")
  resultAmendmentsApproved ResultAmendmentRecord[] @relation("ResultAmendmentApprovedBy")
  resultAmendmentsApplied ResultAmendmentRecord[] @relation("ResultAmendmentAppliedBy")
  transcriptRecordsAsStudent TranscriptRecord[] @relation("TranscriptStudentRecords")
  transcriptRecordsGenerated TranscriptRecord[] @relation("TranscriptRecordGeneratedBy")
  transcriptVersionsGenerated TranscriptVersion[] @relation("TranscriptVersionGeneratedBy")
  transcriptVersionsIssued TranscriptVersion[] @relation("TranscriptVersionIssuedBy")
  transcriptVerificationTokensIssued TranscriptVerificationToken[] @relation("TranscriptVerificationTokenIssuedBy")
  transcriptRevocationsRequested TranscriptRevocationRecord[] @relation("TranscriptRevocationRequestedBy")
  transcriptRevocationsApplied TranscriptRevocationRecord[] @relation("TranscriptRevocationAppliedBy")
  transcriptRevocationsRejected TranscriptRevocationRecord[] @relation("TranscriptRevocationRejectedBy")
  auditLogs          AuditLog[]          @relation("AuditActor")
  settingsUpdated    DepartmentSetting[] @relation("DepartmentSettingUpdatedBy")
  overrideActions    OverrideAction[]    @relation("OverrideActor")
  overrideApprovals  OverrideAction[]    @relation("OverrideApprover")
  fileObjects        FileObject[]        @relation("FileUploadedBy")

  @@index([departmentId])
  @@map("users")
}

model DepartmentAcademicConfig {
  id                                String      @id @default(cuid())
  departmentId                      String      @unique @map("department_id")
  selfEnrollmentEnabled             Boolean     @default(false) @map("self_enrollment_enabled")
  selfEnrollmentRequiresApproval    Boolean     @default(true) @map("self_enrollment_requires_approval")
  teacherAssignmentRequiredForSession Boolean   @default(true) @map("teacher_assignment_required_for_session")
  attendanceManualOverrideRequiresReason Boolean @default(true) @map("attendance_manual_override_requires_reason")
  biometricAttendanceEnabled        Boolean     @default(false) @map("biometric_attendance_enabled")
  eligibilityEnforcementEnabled     Boolean     @default(true) @map("eligibility_enforcement_enabled")
  attendanceSettingsJson            Json?       @map("attendance_settings_json")
  eligibilitySettingsJson           Json?       @map("eligibility_settings_json")
  updatedByUserId                   String?     @map("updated_by_user_id")
  archivedAt                        DateTime?   @map("archived_at")
  createdAt                         DateTime    @default(now()) @map("created_at")
  updatedAt                         DateTime    @updatedAt @map("updated_at")
  department                        Department  @relation(fields: [departmentId], references: [id])
  updatedByUser                     User?       @relation("AcademicConfigUpdatedBy", fields: [updatedByUserId], references: [id])

  @@map("department_academic_configs")
}

model AcademicProgram {
  id               String               @id @default(cuid())
  departmentId     String               @map("department_id")
  code             String
  name             String
  description      String?
  status           AcademicProgramStatus @default(ACTIVE)
  archivedAt       DateTime?            @map("archived_at")
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")
  department       Department           @relation(fields: [departmentId], references: [id])
  courses          Course[]
  eligibilityRuleBindings EligibilityRuleBinding[]

  @@unique([departmentId, code])
  @@index([departmentId])
  @@map("academic_programs")
}

model AcademicYear {
  id               String             @id @default(cuid())
  departmentId     String             @map("department_id")
  code             String
  name             String
  startDate        DateTime           @map("start_date")
  endDate          DateTime           @map("end_date")
  isCurrent        Boolean            @default(false) @map("is_current")
  status           AcademicYearStatus @default(PLANNED)
  archivedAt       DateTime?          @map("archived_at")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")
  department       Department         @relation(fields: [departmentId], references: [id])
  academicTerms    AcademicTerm[]

  @@unique([departmentId, code])
  @@index([departmentId])
  @@map("academic_years")
}

model AcademicTerm {
  id               String             @id @default(cuid())
  departmentId     String             @map("department_id")
  academicYearId   String             @map("academic_year_id")
  code             String
  name             String
  sequence         Int
  startDate        DateTime           @map("start_date")
  endDate          DateTime           @map("end_date")
  enrollmentStartAt DateTime?         @map("enrollment_start_at")
  enrollmentEndAt  DateTime?          @map("enrollment_end_at")
  status           AcademicTermStatus @default(PLANNED)
  archivedAt       DateTime?          @map("archived_at")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")
  department       Department         @relation(fields: [departmentId], references: [id])
  academicYear     AcademicYear       @relation(fields: [academicYearId], references: [id])
  courseOfferings  CourseOffering[]
  enrollments      Enrollment[]
  eligibilityRuleBindings EligibilityRuleBinding[]
  resultRecords    ResultRecord[]
  gpaRecords       GPARecord[]
  cgpaRecordsAsOf  CGPARecord[]
  resultPublicationBatches ResultPublicationBatch[]
  transcriptTermSummaries TranscriptTermSummary[]

  @@unique([departmentId, code])
  @@index([departmentId])
  @@index([academicYearId])
  @@map("academic_terms")
}

model Course {
  id               String       @id @default(cuid())
  departmentId     String       @map("department_id")
  academicProgramId String?     @map("academic_program_id")
  code             String
  title            String
  description      String?
  creditHours      Decimal      @db.Decimal(4, 2) @map("credit_hours")
  lectureHours     Decimal?     @db.Decimal(4, 2) @map("lecture_hours")
  labHours         Decimal?     @db.Decimal(4, 2) @map("lab_hours")
  status           CourseStatus @default(DRAFT)
  archivedAt       DateTime?    @map("archived_at")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")
  department       Department   @relation(fields: [departmentId], references: [id])
  academicProgram  AcademicProgram? @relation(fields: [academicProgramId], references: [id])
  courseOfferings  CourseOffering[]

  @@unique([departmentId, code])
  @@index([departmentId])
  @@index([academicProgramId])
  @@map("courses")
}

model CourseOffering {
  id               String               @id @default(cuid())
  departmentId     String               @map("department_id")
  courseId         String               @map("course_id")
  academicTermId   String               @map("academic_term_id")
  sectionCode      String               @map("section_code")
  capacity         Int?
  status           CourseOfferingStatus @default(PLANNED)
  visibilityStartAt DateTime?           @map("visibility_start_at")
  visibilityEndAt  DateTime?            @map("visibility_end_at")
  archivedAt       DateTime?            @map("archived_at")
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")
  department       Department           @relation(fields: [departmentId], references: [id])
  course           Course               @relation(fields: [courseId], references: [id])
  academicTerm     AcademicTerm         @relation(fields: [academicTermId], references: [id])
  teacherAssignments TeacherCourseAssignment[]
  enrollments      Enrollment[]
  classSessions    ClassSession[]
  attendanceImportBatches AttendanceImportBatch[]
  eligibilityRuleBindings EligibilityRuleBinding[]
  assignments        Assignment[]
  quizzes            Quiz[]
  quizAttempts       QuizAttempt[]
  gradingRecords     GradingRecord[]
  resultRecords      ResultRecord[]
  transcriptCourseLines TranscriptCourseLine[]

  @@unique([departmentId, academicTermId, courseId, sectionCode])
  @@index([departmentId])
  @@index([courseId])
  @@index([academicTermId])
  @@map("course_offerings")
}

model TeacherCourseAssignment {
  id               String                  @id @default(cuid())
  departmentId     String                  @map("department_id")
  courseOfferingId String                  @map("course_offering_id")
  teacherUserId    String                  @map("teacher_user_id")
  roleCode         String                  @map("role_code")
  status           TeacherAssignmentStatus @default(ACTIVE)
  assignedAt       DateTime                @default(now()) @map("assigned_at")
  unassignedAt     DateTime?               @map("unassigned_at")
  archivedAt       DateTime?               @map("archived_at")
  createdAt        DateTime                @default(now()) @map("created_at")
  updatedAt        DateTime                @updatedAt @map("updated_at")
  department       Department              @relation(fields: [departmentId], references: [id])
  courseOffering   CourseOffering          @relation(fields: [courseOfferingId], references: [id], onDelete: Cascade)
  teacherUser      User                    @relation("TeacherAssignments", fields: [teacherUserId], references: [id])
  classSessions    ClassSession[]

  @@unique([courseOfferingId, teacherUserId, roleCode])
  @@index([departmentId])
  @@index([teacherUserId])
  @@map("teacher_course_assignments")
}

model Enrollment {
  id               String             @id @default(cuid())
  departmentId     String             @map("department_id")
  academicTermId   String             @map("academic_term_id")
  courseOfferingId String             @map("course_offering_id")
  studentUserId    String             @map("student_user_id")
  approvedByUserId String?            @map("approved_by_user_id")
  sourceType       EnrollmentSourceType @default(ADMIN) @map("source_type")
  status           EnrollmentStatus   @default(PENDING)
  eligibilityStatus EligibilityStatus @default(PENDING_REVIEW) @map("eligibility_status")
  eligibilitySnapshotJson Json?       @map("eligibility_snapshot_json")
  enrolledAt       DateTime?          @map("enrolled_at")
  droppedAt        DateTime?          @map("dropped_at")
  archivedAt       DateTime?          @map("archived_at")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")
  department       Department         @relation(fields: [departmentId], references: [id])
  academicTerm     AcademicTerm       @relation(fields: [academicTermId], references: [id])
  courseOffering   CourseOffering     @relation(fields: [courseOfferingId], references: [id], onDelete: Cascade)
  studentUser      User               @relation("StudentEnrollments", fields: [studentUserId], references: [id])
  approvedByUser   User?              @relation("EnrollmentApprovedBy", fields: [approvedByUserId], references: [id])
  attendanceRecords AttendanceRecord[]
  assignmentSubmissions AssignmentSubmission[]
  quizAttempts      QuizAttempt[]
  resultRecords     ResultRecord[]

  @@unique([courseOfferingId, studentUserId])
  @@index([departmentId])
  @@index([academicTermId])
  @@index([studentUserId])
  @@map("enrollments")
}

model ClassSession {
  id               String             @id @default(cuid())
  departmentId     String             @map("department_id")
  courseOfferingId String             @map("course_offering_id")
  teacherAssignmentId String?         @map("teacher_assignment_id")
  sessionCode      String?            @map("session_code")
  title            String?
  scheduledStartAt DateTime           @map("scheduled_start_at")
  scheduledEndAt   DateTime           @map("scheduled_end_at")
  actualStartAt    DateTime?          @map("actual_start_at")
  actualEndAt      DateTime?          @map("actual_end_at")
  location         String?
  externalSourceRef String?           @map("external_source_ref")
  status           ClassSessionStatus @default(SCHEDULED)
  lockedAt         DateTime?          @map("locked_at")
  canceledAt       DateTime?          @map("canceled_at")
  archivedAt       DateTime?          @map("archived_at")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")
  department       Department         @relation(fields: [departmentId], references: [id])
  courseOffering   CourseOffering     @relation(fields: [courseOfferingId], references: [id], onDelete: Cascade)
  teacherAssignment TeacherCourseAssignment? @relation(fields: [teacherAssignmentId], references: [id])
  attendanceRecords AttendanceRecord[]
  attendanceImportBatches AttendanceImportBatch[]

  @@unique([courseOfferingId, sessionCode])
  @@index([departmentId])
  @@index([courseOfferingId])
  @@map("class_sessions")
}

model AttendanceRecord {
  id               String               @id @default(cuid())
  departmentId     String               @map("department_id")
  classSessionId   String               @map("class_session_id")
  enrollmentId     String               @map("enrollment_id")
  studentUserId    String               @map("student_user_id")
  markedByUserId   String?              @map("marked_by_user_id")
  overrideByUserId String?              @map("override_by_user_id")
  status           AttendanceRecordStatus
  sourceType       AttendanceSourceType @map("source_type")
  externalSourceRef String?             @map("external_source_ref")
  sourcePayloadJson Json?               @map("source_payload_json")
  overrideReason   String?              @map("override_reason")
  markedAt         DateTime             @default(now()) @map("marked_at")
  archivedAt       DateTime?            @map("archived_at")
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")
  department       Department           @relation(fields: [departmentId], references: [id])
  classSession     ClassSession         @relation(fields: [classSessionId], references: [id], onDelete: Cascade)
  enrollment       Enrollment           @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  studentUser      User                 @relation("AttendanceStudent", fields: [studentUserId], references: [id])
  markedByUser     User?                @relation("AttendanceMarkedBy", fields: [markedByUserId], references: [id])
  overrideByUser   User?                @relation("AttendanceOverrideBy", fields: [overrideByUserId], references: [id])

  @@unique([classSessionId, enrollmentId])
  @@index([departmentId])
  @@index([studentUserId])
  @@map("attendance_records")
}

model AttendanceImportBatch {
  id               String                    @id @default(cuid())
  departmentId     String                    @map("department_id")
  courseOfferingId String?                   @map("course_offering_id")
  classSessionId   String?                   @map("class_session_id")
  uploadedByUserId String                    @map("uploaded_by_user_id")
  reviewedByUserId String?                   @map("reviewed_by_user_id")
  sourceType       AttendanceImportSourceType @map("source_type")
  externalSystemName String?                 @map("external_system_name")
  externalBatchRef String?                   @map("external_batch_ref")
  importWindowStartAt DateTime?              @map("import_window_start_at")
  importWindowEndAt DateTime?                @map("import_window_end_at")
  totalRows         Int                      @default(0) @map("total_rows")
  processedRows     Int                      @default(0) @map("processed_rows")
  successfulRows    Int                      @default(0) @map("successful_rows")
  failedRows        Int                      @default(0) @map("failed_rows")
  status            AttendanceImportBatchStatus @default(RECEIVED)
  validationSummaryJson Json?                @map("validation_summary_json")
  processedAt       DateTime?                @map("processed_at")
  archivedAt        DateTime?                @map("archived_at")
  createdAt         DateTime                 @default(now()) @map("created_at")
  updatedAt         DateTime                 @updatedAt @map("updated_at")
  department        Department               @relation(fields: [departmentId], references: [id])
  courseOffering    CourseOffering?          @relation(fields: [courseOfferingId], references: [id])
  classSession      ClassSession?            @relation(fields: [classSessionId], references: [id])
  uploadedByUser    User                     @relation("AttendanceImportUploadedBy", fields: [uploadedByUserId], references: [id])
  reviewedByUser    User?                    @relation("AttendanceImportReviewedBy", fields: [reviewedByUserId], references: [id])

  @@index([departmentId])
  @@index([courseOfferingId])
  @@index([classSessionId])
  @@map("attendance_import_batches")
}

model EligibilityRuleDefinition {
  id               String               @id @default(cuid())
  departmentId     String               @map("department_id")
  code             String
  name             String
  description      String?
  scope            EligibilityRuleScope
  criteriaJson     Json                 @map("criteria_json")
  isActive         Boolean              @default(true) @map("is_active")
  version          Int                  @default(1)
  archivedAt       DateTime?            @map("archived_at")
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")
  department       Department           @relation(fields: [departmentId], references: [id])
  bindings         EligibilityRuleBinding[]

  @@unique([departmentId, code, version])
  @@index([departmentId])
  @@map("eligibility_rule_definitions")
}

model EligibilityRuleBinding {
  id               String               @id @default(cuid())
  departmentId     String               @map("department_id")
  eligibilityRuleDefinitionId String    @map("eligibility_rule_definition_id")
  academicProgramId String?             @map("academic_program_id")
  academicTermId   String?              @map("academic_term_id")
  courseOfferingId String?              @map("course_offering_id")
  isActive         Boolean              @default(true) @map("is_active")
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")
  department       Department           @relation(fields: [departmentId], references: [id])
  eligibilityRuleDefinition EligibilityRuleDefinition @relation(fields: [eligibilityRuleDefinitionId], references: [id], onDelete: Cascade)
  academicProgram  AcademicProgram?     @relation(fields: [academicProgramId], references: [id])
  academicTerm     AcademicTerm?        @relation(fields: [academicTermId], references: [id])
  courseOffering   CourseOffering?      @relation(fields: [courseOfferingId], references: [id])

  @@index([departmentId])
  @@index([eligibilityRuleDefinitionId])
  @@map("eligibility_rule_bindings")
}

model Assignment {
  id                    String            @id @default(cuid())
  departmentId          String            @map("department_id")
  courseOfferingId      String            @map("course_offering_id")
  title                 String
  instructions          String?
  status                AssignmentStatus  @default(DRAFT)
  maxPoints             Decimal           @db.Decimal(6, 2) @map("max_points")
  availableFrom         DateTime?         @map("available_from")
  dueAt                 DateTime?         @map("due_at")
  closeAt               DateTime?         @map("close_at")
  allowLateSubmission   Boolean           @default(false) @map("allow_late_submission")
  maxLateMinutes        Int?              @map("max_late_minutes")
  maxSubmissionCount    Int               @default(1) @map("max_submission_count")
  maxFileCount          Int               @default(5) @map("max_file_count")
  maxFileSizeBytes      Int?              @map("max_file_size_bytes")
  allowedMimeTypes      String[]          @default([]) @map("allowed_mime_types")
  plagiarismCheckEnabled Boolean          @default(false) @map("plagiarism_check_enabled")
  evaluationConfigJson  Json?             @map("evaluation_config_json")
  publishedAt           DateTime?         @map("published_at")
  archivedAt            DateTime?         @map("archived_at")
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")
  department            Department        @relation(fields: [departmentId], references: [id])
  courseOffering        CourseOffering    @relation(fields: [courseOfferingId], references: [id], onDelete: Cascade)
  submissions           AssignmentSubmission[]

  @@index([departmentId])
  @@index([courseOfferingId])
  @@map("assignments")
}

model AssignmentSubmission {
  id                    String            @id @default(cuid())
  departmentId          String            @map("department_id")
  assignmentId          String            @map("assignment_id")
  enrollmentId          String            @map("enrollment_id")
  attemptNumber         Int               @default(1) @map("attempt_number")
  status                SubmissionStatus  @default(SUBMITTED)
  submittedAt           DateTime          @default(now()) @map("submitted_at")
  isLate                Boolean           @default(false) @map("is_late")
  lateByMinutes         Int?              @map("late_by_minutes")
  notes                 String?
  evaluationHookStatus  EvaluationHookStatus @default(NOT_REQUESTED) @map("evaluation_hook_status")
  evaluationHookRef     String?           @map("evaluation_hook_ref")
  archivedAt            DateTime?         @map("archived_at")
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")
  department            Department        @relation(fields: [departmentId], references: [id])
  assignment            Assignment        @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  enrollment            Enrollment        @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  submissionFiles       SubmissionFile[]
  gradingRecords        GradingRecord[]   @relation("SubmissionGradingRecords")

  @@unique([assignmentId, enrollmentId, attemptNumber])
  @@index([departmentId])
  @@index([enrollmentId])
  @@map("assignment_submissions")
}

model SubmissionFile {
  id                    String            @id @default(cuid())
  departmentId          String            @map("department_id")
  assignmentSubmissionId String           @map("assignment_submission_id")
  fileObjectId          String            @map("file_object_id")
  displayName           String?           @map("display_name")
  sortOrder             Int               @default(0) @map("sort_order")
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")
  department            Department        @relation(fields: [departmentId], references: [id])
  assignmentSubmission  AssignmentSubmission @relation(fields: [assignmentSubmissionId], references: [id], onDelete: Cascade)
  fileObject            FileObject        @relation(fields: [fileObjectId], references: [id], onDelete: Cascade)

  @@index([departmentId])
  @@index([assignmentSubmissionId])
  @@index([fileObjectId])
  @@map("submission_files")
}

model Quiz {
  id                    String            @id @default(cuid())
  departmentId          String            @map("department_id")
  courseOfferingId      String            @map("course_offering_id")
  title                 String
  instructions          String?
  status                QuizStatus        @default(DRAFT)
  maxPoints             Decimal           @db.Decimal(6, 2) @map("max_points")
  availableFrom         DateTime?         @map("available_from")
  startsAt              DateTime?         @map("starts_at")
  dueAt                 DateTime?         @map("due_at")
  closeAt               DateTime?         @map("close_at")
  timeLimitMinutes      Int?              @map("time_limit_minutes")
  maxAttempts           Int               @default(1) @map("max_attempts")
  shuffleQuestions      Boolean           @default(false) @map("shuffle_questions")
  shuffleOptions        Boolean           @default(false) @map("shuffle_options")
  autoGradingEnabled    Boolean           @default(true) @map("auto_grading_enabled")
  evaluationConfigJson  Json?             @map("evaluation_config_json")
  publishedAt           DateTime?         @map("published_at")
  archivedAt            DateTime?         @map("archived_at")
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")
  department            Department        @relation(fields: [departmentId], references: [id])
  courseOffering        CourseOffering    @relation(fields: [courseOfferingId], references: [id], onDelete: Cascade)
  questions             QuizQuestion[]
  attempts              QuizAttempt[]

  @@index([departmentId])
  @@index([courseOfferingId])
  @@map("quizzes")
}

model QuizQuestion {
  id                    String            @id @default(cuid())
  departmentId          String            @map("department_id")
  quizId                String            @map("quiz_id")
  prompt                String
  questionType          QuizQuestionType  @map("question_type")
  sortOrder             Int               @default(0) @map("sort_order")
  maxPoints             Decimal           @db.Decimal(6, 2) @map("max_points")
  isRequired            Boolean           @default(true) @map("is_required")
  configJson            Json?             @map("config_json")
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")
  department            Department        @relation(fields: [departmentId], references: [id])
  quiz                  Quiz              @relation(fields: [quizId], references: [id], onDelete: Cascade)
  options               QuizOption[]
  responses             QuizResponse[]

  @@index([departmentId])
  @@index([quizId])
  @@map("quiz_questions")
}

model QuizOption {
  id                    String            @id @default(cuid())
  departmentId          String            @map("department_id")
  quizQuestionId        String            @map("quiz_question_id")
  label                 String
  sortOrder             Int               @default(0) @map("sort_order")
  isCorrect             Boolean           @default(false) @map("is_correct")
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")
  department            Department        @relation(fields: [departmentId], references: [id])
  quizQuestion          QuizQuestion      @relation(fields: [quizQuestionId], references: [id], onDelete: Cascade)
  responses             QuizResponse[]

  @@index([departmentId])
  @@index([quizQuestionId])
  @@map("quiz_options")
}

model QuizAttempt {
  id                    String            @id @default(cuid())
  departmentId          String            @map("department_id")
  courseOfferingId      String            @map("course_offering_id")
  quizId                String            @map("quiz_id")
  enrollmentId          String            @map("enrollment_id")
  attemptNumber         Int               @default(1) @map("attempt_number")
  status                QuizAttemptStatus @default(IN_PROGRESS)
  startedAt             DateTime          @default(now()) @map("started_at")
  submittedAt           DateTime?         @map("submitted_at")
  autoSubmittedAt       DateTime?         @map("auto_submitted_at")
  timeLimitMinutesSnapshot Int?           @map("time_limit_minutes_snapshot")
  evaluationHookStatus  EvaluationHookStatus @default(NOT_REQUESTED) @map("evaluation_hook_status")
  evaluationHookRef     String?           @map("evaluation_hook_ref")
  archivedAt            DateTime?         @map("archived_at")
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")
  department            Department        @relation(fields: [departmentId], references: [id])
  courseOffering        CourseOffering    @relation(fields: [courseOfferingId], references: [id])
  quiz                  Quiz              @relation(fields: [quizId], references: [id], onDelete: Cascade)
  enrollment            Enrollment        @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  responses             QuizResponse[]
  gradingRecords        GradingRecord[]   @relation("QuizAttemptGradingRecords")

  @@unique([quizId, enrollmentId, attemptNumber])
  @@index([departmentId])
  @@index([courseOfferingId])
  @@index([enrollmentId])
  @@map("quiz_attempts")
}

model QuizResponse {
  id                    String            @id @default(cuid())
  departmentId          String            @map("department_id")
  quizAttemptId         String            @map("quiz_attempt_id")
  quizQuestionId        String            @map("quiz_question_id")
  selectedQuizOptionId  String?           @map("selected_quiz_option_id")
  textResponse          String?           @map("text_response")
  pointsAwarded         Decimal?          @db.Decimal(6, 2) @map("points_awarded")
  isCorrect             Boolean?          @map("is_correct")
  answeredAt            DateTime?         @map("answered_at")
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")
  department            Department        @relation(fields: [departmentId], references: [id])
  quizAttempt           QuizAttempt       @relation(fields: [quizAttemptId], references: [id], onDelete: Cascade)
  quizQuestion          QuizQuestion      @relation(fields: [quizQuestionId], references: [id])
  selectedQuizOption    QuizOption?       @relation(fields: [selectedQuizOptionId], references: [id])

  @@unique([quizAttemptId, quizQuestionId])
  @@index([departmentId])
  @@index([quizQuestionId])
  @@map("quiz_responses")
}

model GradingRecord {
  id                    String            @id @default(cuid())
  departmentId          String            @map("department_id")
  courseOfferingId      String            @map("course_offering_id")
  targetType            GradingRecordTargetType @map("target_type")
  assignmentSubmissionId String?          @map("assignment_submission_id")
  quizAttemptId         String?           @map("quiz_attempt_id")
  gradedByUserId        String            @map("graded_by_user_id")
  gradingMode           GradingMode       @map("grading_mode")
  pointsAwarded         Decimal           @db.Decimal(6, 2) @map("points_awarded")
  feedback              String?
  isRegrade             Boolean           @default(false) @map("is_regrade")
  regradeReason         String?           @map("regrade_reason")
  gradedAt              DateTime          @default(now()) @map("graded_at")
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")
  department            Department        @relation(fields: [departmentId], references: [id])
  courseOffering        CourseOffering    @relation(fields: [courseOfferingId], references: [id])
  assignmentSubmission  AssignmentSubmission? @relation("SubmissionGradingRecords", fields: [assignmentSubmissionId], references: [id])
  quizAttempt           QuizAttempt?      @relation("QuizAttemptGradingRecords", fields: [quizAttemptId], references: [id])
  gradedByUser          User              @relation("GradingRecords", fields: [gradedByUserId], references: [id])
  resultComponents      ResultComponent[]

  @@index([departmentId])
  @@index([courseOfferingId])
  @@index([assignmentSubmissionId])
  @@index([quizAttemptId])
  @@map("grading_records")
}

model Role {
  id                String           @id @default(cuid())
  departmentId      String           @map("department_id")
  code              String
  name              String
  description       String?
  archivedAt        DateTime?        @map("archived_at")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")
  department        Department       @relation(fields: [departmentId], references: [id])
  userRoles         UserRole[]
  rolePermissions   RolePermission[]

  @@unique([departmentId, code])
  @@index([departmentId])
  @@map("roles")
}

model Permission {
  id               String           @id @default(cuid())
  code             String           @unique
  resource         String
  action           String
  scope            PermissionScope
  description      String?
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")
  rolePermissions  RolePermission[]

  @@map("permissions")
}

model UserRole {
  id               String      @id @default(cuid())
  userId           String      @map("user_id")
  roleId           String      @map("role_id")
  departmentId     String      @map("department_id")
  assignedByUserId String?     @map("assigned_by_user_id")
  expiresAt        DateTime?   @map("expires_at")
  revokedAt        DateTime?   @map("revoked_at")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")
  user             User        @relation(fields: [userId], references: [id])
  role             Role        @relation(fields: [roleId], references: [id])
  department       Department  @relation(fields: [departmentId], references: [id])

  @@unique([userId, roleId, departmentId])
  @@index([departmentId])
  @@map("user_roles")
}

model RolePermission {
  id            String      @id @default(cuid())
  roleId        String      @map("role_id")
  permissionId  String      @map("permission_id")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  role          Role        @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission    Permission  @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model Session {
  id                String         @id @default(cuid())
  userId            String         @map("user_id")
  departmentId      String         @map("department_id")
  refreshTokenHash  String         @map("refresh_token_hash")
  deviceFingerprintHash String?    @map("device_fingerprint_hash")
  deviceLabel       String?        @map("device_label")
  isTrustedDevice   Boolean        @default(false) @map("is_trusted_device")
  ipAddress         String?        @map("ip_address")
  lastIpAddress     String?        @map("last_ip_address")
  userAgent         String?        @map("user_agent")
  lastUserAgent     String?        @map("last_user_agent")
  status            SessionStatus  @default(ACTIVE)
  lastSeenAt        DateTime?      @map("last_seen_at")
  stepUpVerifiedAt  DateTime?      @map("step_up_verified_at")
  expiresAt         DateTime       @map("expires_at")
  revokedAt         DateTime?      @map("revoked_at")
  revokedReason     String?        @map("revoked_reason")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  department        Department     @relation(fields: [departmentId], references: [id])

  @@index([userId, departmentId])
  @@index([departmentId])
  @@map("sessions")
}

model LoginAttempt {
  id                   String               @id @default(cuid())
  userId               String?              @map("user_id")
  departmentId         String?              @map("department_id")
  normalizedEmail      String               @map("normalized_email")
  ipAddress            String?              @map("ip_address")
  userAgent            String?              @map("user_agent")
  deviceFingerprintHash String?             @map("device_fingerprint_hash")
  outcome              LoginAttemptOutcome
  failureReason        String?              @map("failure_reason")
  occurredAt           DateTime             @default(now()) @map("occurred_at")
  createdAt            DateTime             @default(now()) @map("created_at")
  updatedAt            DateTime             @updatedAt @map("updated_at")
  user                 User?                @relation(fields: [userId], references: [id])
  department           Department?          @relation(fields: [departmentId], references: [id])

  @@index([normalizedEmail, occurredAt])
  @@index([departmentId, occurredAt])
  @@index([userId, occurredAt])
  @@map("login_attempts")
}

model SuspiciousLoginEvent {
  id                   String                @id @default(cuid())
  userId               String                @map("user_id")
  departmentId         String                @map("department_id")
  sessionId            String?               @map("session_id")
  reason               SuspiciousLoginReason
  ipAddress            String?               @map("ip_address")
  userAgent            String?               @map("user_agent")
  deviceFingerprintHash String?              @map("device_fingerprint_hash")
  riskScore            Int                   @default(0) @map("risk_score")
  requiresStepUp       Boolean               @default(true) @map("requires_step_up")
  reviewedAt           DateTime?             @map("reviewed_at")
  resolvedAt           DateTime?             @map("resolved_at")
  resolutionNotes      String?               @map("resolution_notes")
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")
  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  department           Department            @relation(fields: [departmentId], references: [id])

  @@index([departmentId, createdAt])
  @@index([userId, createdAt])
  @@map("suspicious_login_events")
}

model StepUpRequirement {
  id               String      @id @default(cuid())
  departmentId     String      @map("department_id")
  policyCode       String      @map("policy_code")
  requiredMethods  String[]    @map("required_methods")
  maxAgeSeconds    Int         @map("max_age_seconds")
  requiredRoleCodes String[]   @default([]) @map("required_role_codes")
  isEnabled        Boolean     @default(true) @map("is_enabled")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")
  department       Department  @relation(fields: [departmentId], references: [id])

  @@unique([departmentId, policyCode])
  @@index([departmentId])
  @@map("step_up_requirements")
}

model EmailVerification {
  id             String               @id @default(cuid())
  userId         String               @map("user_id")
  departmentId   String               @map("department_id")
  email          String
  tokenHash      String               @map("token_hash")
  status         VerificationStatus   @default(PENDING)
  expiresAt      DateTime             @map("expires_at")
  verifiedAt     DateTime?            @map("verified_at")
  consumedAt     DateTime?            @map("consumed_at")
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")
  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  department     Department           @relation(fields: [departmentId], references: [id])

  @@index([userId, departmentId])
  @@map("email_verifications")
}

model PasswordReset {
  id             String               @id @default(cuid())
  userId         String               @map("user_id")
  departmentId   String               @map("department_id")
  tokenHash      String               @map("token_hash")
  status         VerificationStatus   @default(PENDING)
  expiresAt      DateTime             @map("expires_at")
  consumedAt     DateTime?            @map("consumed_at")
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")
  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  department     Department           @relation(fields: [departmentId], references: [id])

  @@index([userId, departmentId])
  @@map("password_resets")
}

model TwoFactorMethod {
  id               String              @id @default(cuid())
  userId           String              @map("user_id")
  departmentId     String              @map("department_id")
  methodType       TwoFactorMethodType @map("method_type")
  label            String
  secretEncrypted  String?             @map("secret_encrypted")
  isPrimary        Boolean             @default(false) @map("is_primary")
  verifiedAt       DateTime?           @map("verified_at")
  disabledAt       DateTime?           @map("disabled_at")
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")
  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  department       Department          @relation(fields: [departmentId], references: [id])

  @@index([userId, departmentId])
  @@map("two_factor_methods")
}

model DepartmentSetting {
  id               String      @id @default(cuid())
  departmentId     String      @map("department_id")
  key              String
  valueJson        Json        @map("value_json")
  updatedByUserId  String?     @map("updated_by_user_id")
  archivedAt       DateTime?   @map("archived_at")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")
  department       Department  @relation(fields: [departmentId], references: [id])
  updatedByUser    User?       @relation("DepartmentSettingUpdatedBy", fields: [updatedByUserId], references: [id])

  @@unique([departmentId, key])
  @@index([departmentId])
  @@map("department_settings")
}

model AuditLog {
  id              String          @id @default(cuid())
  requestId       String?         @map("request_id")
  actorUserId     String?         @map("actor_user_id")
  actorType       AuditActorType  @default(USER) @map("actor_type")
  departmentId    String?         @map("department_id")
  action          String
  targetType      String          @map("target_type")
  targetId        String?         @map("target_id")
  outcome         AuditOutcome
  ipAddress       String?         @map("ip_address")
  userAgent       String?         @map("user_agent")
  contextJson     Json?           @map("context_json")
  occurredAt      DateTime        @default(now()) @map("occurred_at")
  actorUser       User?           @relation("AuditActor", fields: [actorUserId], references: [id])
  department      Department?     @relation(fields: [departmentId], references: [id])

  @@index([departmentId, occurredAt])
  @@index([actorUserId, occurredAt])
  @@map("audit_logs")
}

model OverrideAction {
  id               String               @id @default(cuid())
  departmentId     String               @map("department_id")
  actorUserId      String               @map("actor_user_id")
  approvedByUserId String?              @map("approved_by_user_id")
  action           String
  targetType       String               @map("target_type")
  targetId         String?              @map("target_id")
  reason           String
  status           OverrideActionStatus @default(REQUESTED)
  executedAt       DateTime?            @map("executed_at")
  revokedAt        DateTime?            @map("revoked_at")
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")
  department       Department           @relation(fields: [departmentId], references: [id])
  actorUser        User                 @relation("OverrideActor", fields: [actorUserId], references: [id])
  approvedByUser   User?                @relation("OverrideApprover", fields: [approvedByUserId], references: [id])
  resultAmendments ResultAmendmentRecord[]

  @@index([departmentId, createdAt])
  @@map("override_actions")
}

model GradeScale {
  id                String      @id @default(cuid())
  departmentId      String      @map("department_id")
  code              String
  name              String
  description       String?
  isDefault         Boolean     @default(false) @map("is_default")
  isActive          Boolean     @default(true) @map("is_active")
