NODE_ENV=development

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lexora_lms?schema=public
DATABASE_DIRECT_URL=postgresql://postgres:postgres@localhost:5432/lexora_lms?schema=public

REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

JWT_ACCESS_SECRET=replace-with-64-char-random-string
JWT_ACCESS_TTL=15m
JWT_ISSUER=lexora-api
JWT_AUDIENCE=lexora-web

JWT_REFRESH_SECRET=replace-with-another-64-char-random-string
JWT_REFRESH_TTL=30d
REFRESH_TOKEN_COOKIE_NAME=lexora_rt
REFRESH_TOKEN_COOKIE_SECURE=false
REFRESH_TOKEN_COOKIE_DOMAIN=localhost

SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=Lexora LMS
SMTP_FROM_EMAIL=no-reply@lexora.local

OTP_ISSUER=Lexora LMS
OTP_DIGITS=6
OTP_TTL_SECONDS=300
OTP_RATE_LIMIT_PER_WINDOW=5
TWO_FACTOR_ENCRYPTION_KEY=replace-with-32-byte-key

S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=lexora-local
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_BASE_URL=http://localhost:9000/lexora-local

MALWARE_SCANNER_MODE=clamav
MALWARE_SCANNER_HOST=localhost
MALWARE_SCANNER_PORT=3310
MALWARE_SCANNER_TIMEOUT_MS=10000

SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

WEB_APP_URL=http://localhost:3000
API_APP_URL=http://localhost:4000
PUBLIC_VERIFICATION_URL=http://localhost:3000/verify
ALLOWED_ORIGINS=http://localhost:3000

RATE_LIMIT_TTL_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=120
AUTH_RATE_LIMIT_TTL_SECONDS=60
AUTH_RATE_LIMIT_MAX_REQUESTS=10

PORT=4000

